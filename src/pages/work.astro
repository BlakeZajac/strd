---
import Layout from "../layouts/Layout.astro";
import { LayoutHero, LayoutProjectGrid } from "@components";
import {
	getWorkIndexDescription,
	getWorkIndexSchema,
	getWorkIndexTitle,
} from "../lib/work";
---

<Layout
	title={getWorkIndexTitle()}
	description={getWorkIndexDescription()}
	schema={getWorkIndexSchema()}
>
	<LayoutHero
		title="Selected work"
		primaryAction={null}
		secondaryAction={null}
	/>
	<LayoutProjectGrid slugs={["club-training", "southerly-ten", "fulbright"]} />
</Layout>
