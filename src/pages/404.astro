---
import Layout from "../layouts/Layout.astro";
import { LayoutMediaContent } from "@components";
---

<Layout>
	<LayoutMediaContent
		mediaPosition="right"
		mediaPositionStacked="bottom"
		imageSrc="/gallery/landscape/hero.webp"
		imageAlt=""
		imageLoading="eager"
		content="<p class='badge'>404 error</p><h1>Page not found</h1><p>This page doesn't exist. Head back to the galleries or get in touch to book a shoot.</p>"
		primaryAction={{ label: "Back to home", url: "/" }}
		secondaryAction={null}
	/>
</Layout>
