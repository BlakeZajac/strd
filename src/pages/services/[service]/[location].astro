---
import { getCollection } from "astro:content";

import Layout from "../../../layouts/Layout.astro";
import {
  LayoutHero,
  LayoutList2col,
  BlockDetailList,
  LayoutAccordion,
  LayoutProjectGrid,
  LayoutServiceCta,
} from "@components";
import { createServiceLocationSchema } from "../../../lib/schema";
import { url } from "../../../lib/site";

export const prerender = true;

export async function getStaticPaths() {
  const locations = await getCollection("service-locations");

  return locations.map((entry) => ({
    params: {
      service: entry.data.serviceSlug,
      location: entry.data.locationSlug,
    },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const data = entry.data;

const pagePath = `services/${data.serviceSlug}/${data.locationSlug}`;
const ctaUrl = `/contact/?source=seo&campaign=services-${data.serviceSlug}-${data.locationSlug}`;

const schema = createServiceLocationSchema({
  heading: data.heroHeading,
  description: data.heroSubheading,
  areaServed: data.schema?.areaServedOverride ?? data.locationName,
  pageUrl: url(pagePath),
  serviceSlug: data.serviceSlug,
  locationName: data.locationName,
  faqs: data.faqs,
});

const PROCESS_STEPS = [
  {
    title: "Discover",
    description:
      "A focused conversation to understand your business, goals, and what a good outcome looks like.",
  },
  {
    title: "Define",
    description:
      "Scope, structure, and approach agreed in writing before design or development begins.",
  },
  {
    title: "Design",
    description:
      "Considered layouts and visual direction that serve your content and your audience.",
  },
  {
    title: "Develop",
    description:
      "Clean, maintainable WordPress code built for reliability and longevity beyond launch day.",
  },
  {
    title: "Deliver",
    description:
      "A thorough handover with documentation and a clear plan for what comes next.",
  },
];

const aboutContent = `<p>I'm Blake, a Newcastle-based WordPress developer and designer. I work remotely with small businesses and studios across ${data.locationName} and Australia, building WordPress websites that are considered in their design, clean in their code, and built to last.</p><p>I work directly with clients — no account managers or intermediaries — which means clear communication and a consistent point of contact from brief to handover.</p>`;
---

<Layout title={data.title} description={data.metaDescription} schema={schema}>
  <LayoutHero
    title={data.heroHeading}
    description={data.heroSubheading}
    primaryAction={{ label: "Start a project", url: ctaUrl }}
    secondaryAction={{ label: "View recent work", url: "#work" }}
  />

  <LayoutList2col title="About Blake" content={aboutContent} />

  <LayoutList2col title="Who I work with" content={`<p>${data.audience}</p>`} />

  {
    data.servicesList && data.servicesList.length > 0 && (
      <LayoutList2col title="What I do">
        <BlockDetailList items={data.servicesList} />
      </LayoutList2col>
    )
  }

  <LayoutList2col title="How it works">
    <BlockDetailList items={PROCESS_STEPS} />
  </LayoutList2col>

  <LayoutList2col
    title="Working together"
    content={`<p>${data.locationContext}</p>`}
  />

  {
    data.featuredWorkSlugs && data.featuredWorkSlugs.length > 0 && (
      <LayoutProjectGrid id="work" slugs={data.featuredWorkSlugs} />
    )
  }

  {
    data.faqs && data.faqs.length > 0 && (
      <LayoutAccordion
        title="FAQs"
        items={data.faqs.map(({ question, answer }) => ({
          title: question,
          content: answer,
        }))}
      />
    )
  }

  <LayoutServiceCta
    title="Next steps"
    description="Ready to make your next stride? Share a few details about your project and I will get back to you within one business day."
    primaryAction={{ label: "Start a project", url: ctaUrl }}
  />
</Layout>
