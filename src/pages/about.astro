---
import Layout from "../layouts/Layout.astro";
import { LayoutList2col, LayoutList, LayoutLocations } from "@components";
import { createPersonSchema } from "../lib/schema";
import { getServiceLocationLinks } from "../lib/service-locations";

import experienceData from "../content/experience.json";
import socialData from "../content/social.json";

const locationLinks = await getServiceLocationLinks("wordpress-developer");

const aboutDescription =
  "Learn more about Blake Zajac, a Newcastle-based WordPress developer and designer focused on building considered, long-lasting WordPress sites for small businesses.";
---

<Layout
  title="About Blake Zajac | WordPress developer and designer in Newcastle | STRD"
  description={aboutDescription}
  schema={createPersonSchema({
    name: "Blake Zajac",
    jobTitle: "WordPress developer and designer",
    path: "about",
    description: aboutDescription,
    address: { locality: "Newcastle", region: "NSW", country: "AU" },
  })}
>
  <LayoutList2col
    title="Introduction"
    content="<p class='h3'>Hallo, Blake here. I'm a WordPress developer and designer based in Newcastle, Australia, working full-time at Redback Solutions. I specialise in building custom WordPress solutions that help businesses move foward.</p>"
    imageSrc="/headshot-01.jpg"
    imageAlt="Headshot of Blake Zajac"
  />

  <LayoutList2col
    content="<p class='h4'>I find immense joy in problem solving, learning new approaches to development, and working on projects that challenge me to think differently. Originally focused purely on design, I've spent the last several years bridging the gap between design and development—building sites that not only look good, but work well and scale sustainably.</p> <p class='medium'>My approach is grounded in simplicity and functionality. I believe in building websites that balance business goals with user needs, creating experiences that are visually engaging and built to last. When I'm not coding or designing, you'll find me running long distances, cycling around Newcastle, or trying (and often failing) to stick to a consistent reading habit.</p>"
  />

  <!-- {
    locationLinks.length > 0 && (
      <LayoutLocations
        title="Where I work"
        intro="Based in Newcastle, I work remotely with small businesses and studios across Australia."
        links={locationLinks}
      />
    )
  } -->

  <LayoutList type="experience" data={experienceData} />
  <LayoutList type="social" data={socialData} />
</Layout>
