---
import Layout from "../layouts/Layout.astro";
import { LayoutGalleryFeature } from "@components";
import { createHomePageSchema } from "../lib/schema";
import { getGalleryTypes, getGalleryTypePath } from "../lib/gallery";

const types = await getGalleryTypes();

const title = "Blake Zajac — Photographer | Newcastle, NSW";
const description =
  "Photography by Blake Zajac — commercial, lifestyle, landscape and automotive work based in Newcastle, NSW.";

const schema = createHomePageSchema({
  siteName: "Blake Zajac",
  siteDescription: description,
  personName: "Blake Zajac",
  personJobTitle: "Photographer",
});
---

<Layout {title} {description} {schema}>
  <div class="gallery-features">
    {
      types.map((galleryType, index) => (
        <LayoutGalleryFeature
          title={galleryType.data.title}
          href={getGalleryTypePath(galleryType.id)}
          imageSrc={galleryType.data.heroImage}
          loading={index === 0 ? "eager" : "lazy"}
        />
      ))
    }
  </div>
</Layout>
