---
import Layout from "../layouts/Layout.astro";
import { createHomePageSchema } from "../lib/schema";

const title = "Blake Zajac Photography | Newcastle, NSW";
const description =
  "Blake Zajac is a Newcastle-based photographer specialising in commercial, events, portraiture, lifestyle and automotive photography.";

const schema = createHomePageSchema({
  siteName: "Blake Zajac",
  siteDescription: description,
  personName: "Blake Zajac",
  personJobTitle: "Photographer",
});
---

<Layout {title} {description} {schema} showChrome={false}>
  <section class="coming-soon">
    <div class="coming-soon__container l-container">
      <div class="coming-soon__content">
        <p class="coming-soon__label">Coming Soon</p>
        <h1 class="coming-soon__name">Blake Zajac</h1>
        <p class="coming-soon__disciplines">
          Commercial · Lifestyle · Travel · Automotive
        </p>
        <div class="coming-soon__contact">
          <a href="mailto:contact@blakezajac.com" class="coming-soon__link">
            contact@blakezajac.com
          </a>
          <a
            href="https://instagram.com/zajacphoto"
            class="coming-soon__link"
            target="_blank"
            rel="noopener noreferrer"
          >
            @zajacphoto
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
