---
import Layout from "../layouts/Layout.astro";
import {
	LayoutHero,
	LayoutProjectGrid,
	LayoutList2col,
	LayoutList,
} from "@components";
import { createHomePageSchema } from "../lib/schema";
import { url } from "../lib/site";

import experienceData from "../content/experience.json";
import socialData from "../content/social.json";

const title = "WordPress developer and designer in Newcastle | STRD";
const description =
	"WordPress developer and designer in Newcastle, Australia, helping small businesses take considered strides with fast, reliable websites built to last.";

const schema = createHomePageSchema({
	siteName: "STRD",
	siteDescription: description,
	personName: "Blake Zajac",
	personJobTitle: "WordPress developer and designer",
	searchAction: {
		targetTemplate: `${url("")}?s={search_term_string}`,
		queryInput: "required name=search_term_string",
	},
});
---

<Layout {title} {description} {schema}>
	<LayoutHero
		title="Built to perform. <br /> Designed to last."
		description="Making strides through WordPress and design. <br /> Built for businesses and individuals ready to move forward."
		primaryAction={{ label: "View work", url: "/work" }}
		secondaryAction={{ label: "Start a project", url: "/contact" }}
	/>
	<LayoutProjectGrid columns={1} slugs={["club-training"]} />
	<LayoutProjectGrid columns={2} slugs={["southerly-ten", "fulbright"]} />
	<LayoutList2col
		borderTop={false}
		content="<p class='h3'>Blake Zajac is a Newcastle-based WordPress developer and designer at Redback Solutions. He approaches development as problem solving—translating complex requirements into clean, scalable WordPress sites that balance function with form.</p> <p class='h3'>His work spans custom theme development, ecommerce solutions, and modern web applications. From concept to deployment, he focuses on building experiences that perform well, look better, and grow with the business.</p>"
	/>
	<LayoutList type="experience" data={experienceData} />
	<LayoutList type="social" data={socialData} />
</Layout>
