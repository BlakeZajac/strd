---
export const prerender = false;

import { actions } from "astro:actions";

import Layout from "../layouts/Layout.astro";
import { LayoutHero, LayoutContactForm, LayoutList } from "@components";
import { createContactPageSchema } from "../lib/schema";

import socialData from "../content/social.json";

const result = Astro.getActionResult(actions.send);

if (result && !result.error) {
	return Astro.redirect("/contact?status=sent");
}

const description =
	"Share a few details about your project and Blake will be in touch to discuss how you can work together.";
---

<Layout
	title="Start a project | STRD"
	{description}
	schema={createContactPageSchema("Contact Blake Zajac | STRD", "contact", {
		description,
	})}
>
	<LayoutHero
		title="Start a project"
		primaryAction={null}
		secondaryAction={null}
	/>
	<LayoutContactForm />
	<LayoutList type="social" data={socialData} />
</Layout>
