---
interface Props {
	label: string;
	url: string;
	target?: string;
	className?: string;
}

const { label, url, target = "_self", className = "" } = Astro.props;

if (!url && !label) return;

const words = label.split(" ").filter((word) => word !== "");
const totalWords = words.length;
---

<a
	href={url}
	target={target}
	class:list={["link", className]}
	style={`--total-words: ${totalWords};`}
>
	<span class="link__labels">
		<span class="link__label link__label--default">
			{
				words.map((word, index) => (
					<>
						<span class="link__word" style={`--word-index: ${index}`}>
							{word}
						</span>
						{index < words.length - 1 && " "}
					</>
				))
			}
		</span>

		<span class="link__label link__label--hover" aria-hidden="true">
			{
				words.map((word, index) => (
					<>
						<span class="link__word" style={`--word-index: ${index}`}>
							{word}
						</span>
						{index < words.length - 1 && " "}
					</>
				))
			}
		</span>
	</span>
</a>
