---
import BlockVideoImageBackground from "./block-video-image-background.astro";

interface Props {
	className?: string;
	title: string;
	description?: string;
	slug: string;
	overlay?: boolean;
	imageSrcLandscape?: string;
	imageSrcPortrait?: string;
	imageAlt?: string;
	videoSrc?: string;
}

const {
	className,
	title,
	description,
	slug,
	overlay = true,
	imageSrcLandscape,
	imageSrcPortrait,
	imageAlt,
	videoSrc,
} = Astro.props;
---

<a
	class:list={["project-card", className]}
	href={`/work/${slug}`}
	aria-label={`View project: ${title}`}
	data-content-slug={slug}
>
	<div class="project-card__background">
		<BlockVideoImageBackground
			{overlay}
			{imageSrcLandscape}
			{imageSrcPortrait}
			imageAlt={imageAlt ?? title}
			{videoSrc}
		/>
	</div>

	<div class="project-card__content">
		<div class="project-card__content-inner">
			<span class="project-card__title">{title}</span>
			<span class="project-card__text">{description}</span>
		</div>
	</div>
</a>
