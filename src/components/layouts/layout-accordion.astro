---
import LayoutList2col from "./layout-list-2col.astro";

interface Props {
	title?: string;
	items: Array<{ title: string; content: string }>;
	borderTop?: boolean;
	sectionClass?: string;
}

const { title = "FAQs", items, borderTop = true, sectionClass = "" } =
	Astro.props;
---

<LayoutList2col {title} {borderTop} {sectionClass}>
	<div class="accordion">
		{
			items.map(({ title: itemTitle, content }) => (
				<details class="accordion__item">
					<summary class="accordion__summary">
						<span class="accordion__title">{itemTitle}</span>
						<span class="accordion__icon" aria-hidden="true" />
					</summary>

					<div class="accordion__body copy">
						<p>{content}</p>
					</div>
				</details>
			))
		}
	</div>
</LayoutList2col>
