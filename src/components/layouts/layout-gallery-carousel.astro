---
import type { GalleryPhoto } from "../../lib/gallery";

interface Props {
	photos: GalleryPhoto[];
}

const { photos } = Astro.props;
const photosJson = JSON.stringify(photos.map((photo) => photo.src));
const initialSrc = photos[0]?.src ?? "";
---

<section
	class="gallery-carousel"
	aria-roledescription="carousel"
	aria-label="Gallery photos"
	tabindex="0"
>
	<div class="gallery-carousel__layout">
		<button
			type="button"
			class="gallery-carousel__nav gallery-carousel__nav--prev js-gallery-carousel-prev"
			aria-label="Previous photo"
			disabled={photos.length <= 1}
		>
		</button>

		<div class="gallery-carousel__stage">
			<figure class="gallery-carousel__figure">
				<img
					src={initialSrc}
					alt=""
					class="gallery-carousel__image js-gallery-carousel-image"
					decoding="async"
				/>
			</figure>
		</div>

		<button
			type="button"
			class="gallery-carousel__nav gallery-carousel__nav--next js-gallery-carousel-next"
			aria-label="Next photo"
			disabled={photos.length <= 1}
		>
		</button>
	</div>

	{
		photos.length > 1 && (
			<p
				class="gallery-carousel__status js-gallery-carousel-status"
				aria-live="polite"
			>
				<span class="js-gallery-carousel-current">1</span>
				{" / "}
				<span class="js-gallery-carousel-total">{photos.length}</span>
			</p>
		)
	}
</section>

<script type="application/json" id="gallery-carousel-data" set:html={photosJson}
></script>

<script>
	const dataEl = document.getElementById("gallery-carousel-data");
	const photos = dataEl ? JSON.parse(dataEl.textContent || "[]") : [];

	const carousel = document.querySelector(".gallery-carousel");

	if (!carousel || photos.length === 0) {
		// No photos to show.
	} else {
		const image = carousel.querySelector(".js-gallery-carousel-image");
		const prevBtn = carousel.querySelector(".js-gallery-carousel-prev");
		const nextBtn = carousel.querySelector(".js-gallery-carousel-next");
		const currentEl = carousel.querySelector(".js-gallery-carousel-current");

		let currentIndex = 0;

		const showPhoto = (index) => {
			const src = photos[index];

			if (!src) {
				return;
			}

			currentIndex = index;
			image.src = src;
			prevBtn.disabled = index === 0;
			nextBtn.disabled = index === photos.length - 1;

			if (currentEl) {
				currentEl.textContent = String(index + 1);
			}
		};

		prevBtn.addEventListener("click", () => {
			if (currentIndex > 0) {
				showPhoto(currentIndex - 1);
			}
		});

		nextBtn.addEventListener("click", () => {
			if (currentIndex < photos.length - 1) {
				showPhoto(currentIndex + 1);
			}
		});

		document.addEventListener("keydown", (event) => {
			if (event.key === "ArrowLeft" && currentIndex > 0) {
				showPhoto(currentIndex - 1);
			}

			if (event.key === "ArrowRight" && currentIndex < photos.length - 1) {
				showPhoto(currentIndex + 1);
			}
		});

		let touchStartX = 0;

		carousel.addEventListener(
			"touchstart",
			(event) => {
				touchStartX = event.changedTouches[0]?.screenX ?? 0;
			},
			{ passive: true },
		);

		carousel.addEventListener(
			"touchend",
			(event) => {
				const touchEndX = event.changedTouches[0]?.screenX ?? 0;
				const delta = touchEndX - touchStartX;

				if (Math.abs(delta) < 40) {
					return;
				}

				if (delta < 0 && currentIndex < photos.length - 1) {
					showPhoto(currentIndex + 1);
				}

				if (delta > 0 && currentIndex > 0) {
					showPhoto(currentIndex - 1);
				}
			},
			{ passive: true },
		);
	}
</script>
