---
import type { GalleryLightboxPhoto } from "../../lib/gallery";

interface Props {
	photos: GalleryLightboxPhoto[];
}

const { photos } = Astro.props;
const photosJson = JSON.stringify(photos);
---

<dialog class="gallery-lightbox js-gallery-lightbox" aria-label="Photo viewer">
	<div class="gallery-lightbox__inner">
		<button
			type="button"
			class="gallery-lightbox__close js-gallery-lightbox-close"
			aria-label="Close"
		>
		</button>

		<button
			type="button"
			class="gallery-lightbox__nav gallery-lightbox__nav--prev js-gallery-lightbox-prev"
			aria-label="Previous photo"
		>
		</button>

		<figure class="gallery-lightbox__figure">
			<img
				src=""
				alt=""
				class="gallery-lightbox__image js-gallery-lightbox-image"
			/>
			<figcaption class="gallery-lightbox__caption js-gallery-lightbox-caption">
			</figcaption>
		</figure>

		<button
			type="button"
			class="gallery-lightbox__nav gallery-lightbox__nav--next js-gallery-lightbox-next"
			aria-label="Next photo"
		>
		</button>
	</div>
</dialog>

<script type="application/json" id="gallery-lightbox-data" set:html={photosJson}
></script>

<script>
	const dataEl = document.getElementById("gallery-lightbox-data");
	const photos = dataEl ? JSON.parse(dataEl.textContent || "[]") : [];

	const dialog = document.querySelector(".js-gallery-lightbox");
	const image = dialog.querySelector(".js-gallery-lightbox-image");
	const caption = dialog.querySelector(".js-gallery-lightbox-caption");
	const closeBtn = dialog.querySelector(".js-gallery-lightbox-close");
	const prevBtn = dialog.querySelector(".js-gallery-lightbox-prev");
	const nextBtn = dialog.querySelector(".js-gallery-lightbox-next");
	const items = document.querySelectorAll(".js-gallery-item");

	let currentIndex = 0;

	const showPhoto = (index) => {
		const photo = photos[index];

		if (!photo) {
			return;
		}

		currentIndex = index;
		image.src = photo.fullImage;
		image.alt = photo.alt;
		caption.textContent = photo.title;

		prevBtn.disabled = index === 0;
		nextBtn.disabled = index === photos.length - 1;
	};

	const openAt = (index) => {
		showPhoto(index);
		dialog.showModal();
		document.body.style.overflow = "hidden";
	};

	const close = () => {
		dialog.close();
		document.body.style.overflow = "";
	};

	items.forEach((item) => {
		item.addEventListener("click", () => {
			const index = Number(item.getAttribute("data-index"));
			openAt(index);
		});
	});

	closeBtn.addEventListener("click", close);

	prevBtn.addEventListener("click", () => {
		if (currentIndex > 0) {
			showPhoto(currentIndex - 1);
		}
	});

	nextBtn.addEventListener("click", () => {
		if (currentIndex < photos.length - 1) {
			showPhoto(currentIndex + 1);
		}
	});

	dialog.addEventListener("click", (event) => {
		if (event.target === dialog) {
			close();
		}
	});

	dialog.addEventListener("close", () => {
		document.body.style.overflow = "";
	});

	document.addEventListener("keydown", (event) => {
		if (!dialog.open) {
			return;
		}

		if (event.key === "Escape") {
			close();
		}

		if (event.key === "ArrowLeft" && currentIndex > 0) {
			showPhoto(currentIndex - 1);
		}

		if (event.key === "ArrowRight" && currentIndex < photos.length - 1) {
			showPhoto(currentIndex + 1);
		}
	});
</script>
