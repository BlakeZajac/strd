---
import BlockBrand from "../blocks/block-brand.astro";
import BlockOffcanvasTrigger from "../blocks/block-offcanvas-trigger.astro";
import Menu from "../../content/menu.json";

interface Props {
	inverted?: boolean;
}

const { inverted = false } = Astro.props;
const currentPath = Astro.url.pathname;

const normalizePath = (path: string) => path.replace(/\/$/, "") || "/";
const normalizedCurrent = normalizePath(currentPath);
---

<header class:list={["site-header", inverted && "site-header--inverted"]}>
	<div class="site-header__container l-container">
		<BlockBrand
			inverted={inverted}
			loading="eager"
			className="site-header__brand"
		/>

		<nav class="site-header__menu" aria-label="Gallery">
			{
				Menu.items.map((item) => (
					<a
						href={item.href}
						class:list={[
							"site-header__link",
							{
								"site-header__link--active":
									normalizedCurrent === normalizePath(item.href),
							},
						]}
					>
						{item.label}
					</a>
				))
			}
		</nav>

		<BlockOffcanvasTrigger />
	</div>
</header>
