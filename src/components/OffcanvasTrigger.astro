<button class="site-offcanvas-trigger js-site-offcanvas-trigger">
  <span class="site-offcanvas-trigger__icon"></span>
  <span class="u-visually-hidden">Menu</span>
</button>

<script>
  const trigger = document.querySelector(".js-site-offcanvas-trigger");
  const close = document.querySelector(".js-site-offcanvas-close");

  trigger?.addEventListener("click", () => {
    document.body.classList.add("offcanvas-active");
  });

  close?.addEventListener("click", () => {
    document.body.classList.remove("offcanvas-active");
  });
</script>
