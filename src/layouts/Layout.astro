---
import Analytics from "@vercel/analytics/astro";

import LayoutHeader from "../components/layouts/layout-header.astro";
import LayoutFooter from "../components/layouts/layout-footer.astro";
import LayoutOffcanvas from "../components/layouts/layout-offcanvas.astro";

import { DEFAULT_OG_IMAGE, url as siteUrl } from "../lib/site";

import "../scss/style.scss";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  schema?: any;
  invertedHeader?: boolean;
}

const {
  title = "Blake Zajac — Photographer | Newcastle, NSW",
  description = "Photography by Blake Zajac — lifestyle, landscape and automotive work based in Newcastle, NSW.",
  ogImage = DEFAULT_OG_IMAGE,
  schema,
  invertedHeader = false,
} = Astro.props;

const pageUrl = Astro.url.href;
const ogImageUrl = siteUrl(ogImage);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />

    {/* Base viewport and page description */}
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />

    {/* Open Graph (Facebook, LinkedIn, etc.) */}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImageUrl} />

    {/* Twitter cards */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {/* Site assets and generator */}
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="icon" type="image/svg+xml" href="/logo-black.svg" />
    <link rel="stylesheet" href="https://use.typekit.net/lec4mqw.css" />
    <meta name="generator" content={Astro.generator} />

    {/* Document title */}
    <title>{title}</title>

    {/* Structured data (JSON-LD) */}
    {
      schema && (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
      )
    }
  </head>
  <body>
    <LayoutHeader inverted={invertedHeader} />

    <main class="site-main">
      <slot />
    </main>

    <LayoutFooter />
    <LayoutOffcanvas />
    <Analytics />
  </body>
</html>
